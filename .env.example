# GreekTax local development defaults — copy to `.env` and adjust as needed.
# `.env` is gitignored; this file is the tracked template.

PYTHONPATH=src
FLASK_APP=greektax.backend.app:create_app
FLASK_DEBUG=1

# Allow browser front-ends served from common dev ports (comma-separated).
# Production sets this to the deployed origin (e.g. https://cognisys.gr).
GREEKTAX_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5000,http://localhost:5000

# Optional: cap inbound JSON payload size in bytes (default 64 KiB / 65536).
# GREEKTAX_MAX_REQUEST_BYTES=65536
